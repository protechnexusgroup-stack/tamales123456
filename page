  .value-title { font-family: 'Barlow Condensed', sans-serif; font-size: 1.2rem; font-weight: 700; margin-bottom: 8px; }
  .value-desc { font-size: 0.88rem; color: var(--text-muted); line-height: 1.65; }

  /* ─── FOOTER ─── */
  footer {
    background: #060e1c; color: rgba(255,255,255,0.65);
    padding: 56px 5vw 32px;
  }
  .footer-grid {
