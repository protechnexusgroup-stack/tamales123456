  }
  .cta-strip p { color: rgba(255,255,255,0.75); margin-bottom: 30px; font-size: 1rem; }
  .cta-btns { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }

  /* ─── PAGE: SERVICE DETAIL ─── */
  .service-hero {
    background: linear-gradient(135deg, var(--brand-dark) 0%, var(--brand-navy) 100%);
    padding: 70px 5vw 60px;
  }
  .service-hero h1 {
    font-size: clamp(2rem, 4.5vw, 3.2rem); font-weight: 800;
    color: white; margin-bottom: 16px;
  }
  .service-hero p { color: rgba(255,255,255,0.75); max-width: 660px; margin-bottom: 28px; font-size: 1rem; }
  .breadcrumb {
    font-size: 0.8rem; color: rgba(255,255,255,0.5); margin-bottom: 24px;
  }
  .breadcrumb span { color: var(--brand-accent); }

  .service-block { margin-bottom: 40px; }
  .service-block h3 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 1.35rem; font-weight: 700; color: var(--text-main);
    margin-bottom: 12px; padding-bottom: 10px;
    border-bottom: 2px solid var(--brand-accent);
  }
  .service-block p { color: var(--text-muted); font-size: 0.95rem; line-height: 1.7; }

  .diff-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; margin-top: 16px; }
  .diff-card {
    background: var(--brand-light); border-radius: var(--radius);
    padding: 24px; border-left: 4px solid var(--brand-accent);
  }
  .diff-card h4 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 1.1rem; font-weight: 700; margin-bottom: 8px; color: var(--text-main);
  }
  .diff-card p { font-size: 0.88rem; color: var(--text-muted); }

  /* ─── CONTACT ─── */
  .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: start; }
