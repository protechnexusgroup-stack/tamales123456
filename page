  .local-feat-icon { font-size: 1.5rem; flex-shrink: 0; }
  .local-feat-title { font-family: 'Barlow Condensed', sans-serif; font-size: 1rem; font-weight: 700; margin-bottom: 4px; }
  .local-feat-desc { font-size: 0.82rem; color: var(--text-muted); }
